# ============================================
# SugoBay — Master Environment Variables
# ============================================
# All credentials in one place. Copy values to:
#   sugobay_app/.env      (Flutter app)
#   sugobay_admin/.env     (React admin panel)
#
# NEVER commit real credentials to git.
# ============================================

# ── SUPABASE ──────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...paste-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...paste-your-service-role-key

# ── GOOGLE OAUTH ──────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GOOGLE_WEB_CLIENT_ID=123456789.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=123456789.apps.googleusercontent.com

# ── FACEBOOK OAUTH ────────────────────────────
# Meta Developers → Your App → Settings → Basic
FACEBOOK_APP_ID=1234567890
FACEBOOK_CLIENT_TOKEN=abcdef1234567890

# ── FIREBASE (Push Notifications) ─────────────
# Firebase Console → Project Settings → Cloud Messaging
FIREBASE_SERVER_KEY=AAAA...your-fcm-server-key
# Also place google-services.json in sugobay_app/android/app/

# ── TWILIO (Phone OTP via Supabase) ──────────
# Configure in Supabase Dashboard → Auth → Phone Provider
# These go in Supabase dashboard, NOT in your code
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
